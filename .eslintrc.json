{
  "extends": ["next/core-web-vitals", "next/typescript", "plugin:jsx-a11y/recommended", "prettier"],
  "plugins": ["jsx-a11y"],
  "rules": {
    "no-console": "warn",
    "@typescript-eslint/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_"
      }
    ]
  }
}
