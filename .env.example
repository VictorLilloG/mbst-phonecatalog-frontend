# Public environment variables — these are embedded in the browser bundle.
# Copy this file to .env.local and fill in the values for your environment.

# The canonical URL of the deployed site (no trailing slash).
# Used for: metadataBase, og:url, sitemap, robots.txt
# - Local dev:  http://localhost:3000
# - Production: https://mbst-phonecatalog-frontend.vercel.app
# NEXT_PUBLIC_SITE_URL=https://mbst-phonecatalog-frontend.vercel.app

# Base URL for the phones API (leave blank to use the default).
# NEXT_PUBLIC_API_BASE_URL=https://prueba-tecnica-api-tienda-moviles.onrender.com

# API authentication key.
# NEXT_PUBLIC_API_KEY=87909682e6cd74208f41a6ef39fe4191
